{
  "name": "cli",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "packages/cli/src",
  "tags": ["scope:apps", "lang:ts"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @codeflow/cli build",
        "cwd": "."
      },
      "inputs": ["production"],
      "outputs": ["{projectRoot}/dist"]
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @codeflow/cli clean",
        "cwd": "."
      }
    }
  }
}
