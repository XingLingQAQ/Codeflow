{
  "name": "CodeFlow",
  "version": "1.0.0",
  "description": "Next-generation AI integrated development environment",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint packages/**/src/**/*.ts",
    "format": "prettier --write \"packages/**/src/**/*.{ts,tsx}\"",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e:all": "node scripts/test-all-e2e.mjs",
    "check:garbled-comments": "node scripts/check-garbled-comments.mjs",
    "check:api-contracts": "node scripts/check-api-contracts.mjs",
    "nx:build": "nx run-many -t build",
    "nx:test": "nx run-many -t test",
    "nx:lint": "nx run-many -t lint",
    "nx:graph": "nx graph",
    "nx:affected": "nx affected -t build test lint"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@nx/js": "^22.5.4",
    "@types/node": "^25.0.6",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "nx": "^22.5.4",
    "playwright": "^1.58.2",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@playwright/mcp": "^0.0.68"
  }
}
