{
  "name": "backend",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "backend",
  "tags": ["scope:apps", "lang:go"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "metadata": {
        "description": "开发构建 (CGO_ENABLED=1, 依赖 go-sqlite3)"
      },
      "options": {
        "command": "make build",
        "cwd": "backend"
      },
      "inputs": ["production"],
      "outputs": ["{projectRoot}/build"]
    },
    "build-embedded": {
      "executor": "nx:run-commands",
      "metadata": {
        "description": "嵌入式发布构建 (CGO_ENABLED=0, 静态链接, 含前端 dist)"
      },
      "dependsOn": ["desktop:build"],
      "options": {
        "command": "make build-all",
        "cwd": "backend"
      },
      "inputs": ["production"],
      "outputs": ["{projectRoot}/build"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "make test",
        "cwd": "backend"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "make lint",
        "cwd": "backend"
      }
    },
    "fmt": {
      "executor": "nx:run-commands",
      "options": {
        "command": "make fmt",
        "cwd": "backend"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "make dev",
        "cwd": "backend"
      }
    }
  }
}
