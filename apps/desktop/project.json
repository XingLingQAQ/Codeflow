{
  "name": "desktop",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/desktop",
  "tags": ["scope:apps", "lang:ts", "platform:desktop"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm dev",
        "cwd": "apps/desktop"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["core:build"],
      "options": {
        "command": "pnpm build",
        "cwd": "apps/desktop"
      },
      "inputs": ["production"],
      "outputs": ["{projectRoot}/dist"]
    },
    "tauri-dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tauri:dev",
        "cwd": "apps/desktop"
      }
    },
    "tauri-build": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "pnpm tauri:build",
        "cwd": "apps/desktop"
      },
      "outputs": ["{projectRoot}/src-tauri/target/release"]
    }
  }
}
